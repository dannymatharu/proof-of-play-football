{
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "allowJs": true,
    "jsx": "react",
    "module": "commonjs",
    "strict": true,
    "target": "ES2017",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
